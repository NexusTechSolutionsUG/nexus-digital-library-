<?xml version="1.0" encoding="utf-8"?>
<full-backup-content>
    <!-- Deny sensitive Nexus data from legacy Android backup surfaces. -->
    <exclude domain="sharedpref" path="nexus_auth_prefs.xml" />
    <exclude domain="sharedpref" path="nexus_secure_auth_prefs.xml" />
    <exclude domain="database" path="high_school_library_db" />
    <exclude domain="database" path="high_school_library_db-shm" />
    <exclude domain="database" path="high_school_library_db-wal" />
    <exclude domain="file" path="exports/" />
    <exclude domain="file" path="attachments/" />
</full-backup-content>
