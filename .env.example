# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY=MY_GEMINI_API_KEY

# Supabase Configurations: Configured via Secrets in AI Studio
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=placeholder-anon-key-12345

# STAFF_ACCESS_CODE: Debug/demo-only staff signup gate; production staff roles must be approved server-side.
STAFF_ACCESS_CODE=change-me-before-release

# DEMO_AUTH_ENABLED: Keep false for production. Set true only in debug demo builds to enable local sandbox auth.
DEMO_AUTH_ENABLED=false
